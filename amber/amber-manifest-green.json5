{
  manifest_version: "0.1.0",

  program: {
    image: "ghcr.io/MichaelY310/devops-green-agent:latest",
    entrypoint: ["uv", "run", "python", "server.py", "--host", "0.0.0.0", "--port", "9009"],
    env: {
      LOG_LEVEL: "INFO",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 9009 }
      ]
    }
  },

  // No secrets required — the green agent only orchestrates Docker containers and runs tests.
  // API keys belong to the purple agent.
  config_schema: {
    type: "object",
    properties: {},
    required: [],
    additionalProperties: false,
  },

  slots: {
    proxy: { kind: "a2a" },
    purple_agent: { kind: "a2a" },  // outbound: green -> purple
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" }
  },

  exports: {
    a2a: "a2a"
  },

  metadata: {
    // Default assessment config sent to the green agent.
    // task_ids can be overridden at submission time to target specific tasks.
    assessment_config: {
      task_type: "issue_resolving",  // issue_resolving | build_bugfix | monitoring | test_generation
    },

    // Must match Agent.required_roles in src/green_agent/agent.py
    participant_roles: ["purple_agent"],
  }
}
