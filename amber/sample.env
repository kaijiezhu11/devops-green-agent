# DevOps-Gym Benchmark Configuration

# Task type to evaluate: issue_resolving | build_bugfix | monitoring | test_generation
TASK_TYPE=issue_resolving

# Optional: specific task IDs to run (JSON array format, leave empty to run all tasks in the type)
# TASK_IDS=["issue_resolving/containerd__containerd-4978"]

# Anthropic API key for the Claude Code purple agent
ANTHROPIC_API_KEY=sk-ant-your-key-here
