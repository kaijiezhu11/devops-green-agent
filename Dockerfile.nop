FROM python:3.11-slim

WORKDIR /app

# Install uv
RUN pip install uv

# Copy project files
COPY pyproject.toml uv.lock ./
COPY src/ ./src/

# Copy the nop agent start script
COPY start_nop_agent.py ./

# Install dependencies
RUN uv sync --frozen

# Expose port
EXPOSE 9009

# Run the nop agent
ENTRYPOINT ["uv", "run", "python", "start_nop_agent.py"]
CMD ["--host", "0.0.0.0", "--port", "9009"]
